PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/BIPs-Hub
PGSSL=false
TRUST_PROXY=false

# Allowed frontend origins, comma-separated
CORS_ORIGINS=http://localhost:3000,https://bicol-indigenous-peoples-hub.vercel.app

# Firebase Admin credentials for verifying ID tokens
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
WRITE_RATE_LIMIT_MAX=60
EMERGENCY_RATE_LIMIT_MAX=10
